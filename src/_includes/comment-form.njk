<!-- Comment Form Component -->
<div class="comment-form-container mt-8 p-6 bg-gray-50 rounded-lg">
    <h3 class="text-xl font-semibold mb-4">Leave a Comment</h3>
    
    <form id="comment-form" class="space-y-4">
        <input type="hidden" name="postFilename" value="{{ filename }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="form-group">
                <label for="comment-name" class="block text-sm font-medium text-gray-700 mb-1">
                    Name <span class="text-red-500">*</span>
                </label>
                <input 
                    type="text" 
                    id="comment-name" 
                    name="name" 
                    required 
                    aria-describedby="name-help"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                >
                <div id="name-help" class="sr-only">Enter your full name, maximum 100 characters</div>
            </div>
            
            <div class="form-group">
                <label for="comment-email" class="block text-sm font-medium text-gray-700 mb-1">
                    Email <span class="text-red-500">*</span>
                </label>
                <input 
                    type="email" 
                    id="comment-email" 
                    name="email" 
                    required 
                    aria-describedby="email-help"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                >
                <small class="text-gray-500 text-xs">Email will not be published</small>
                <div id="email-help" class="sr-only">Enter a valid email address for comment notifications</div>
            </div>
        </div>
        
        <div class="form-group">
            <label for="comment-message" class="block text-sm font-medium text-gray-700 mb-1">
                Comment <span class="text-red-500">*</span>
            </label>
            <textarea 
                id="comment-message" 
                name="message" 
                required 
                rows="4" 
                aria-describedby="message-help char-count"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            ></textarea>
            <div id="message-help" class="sr-only">Enter your comment, minimum 5 characters, maximum 5000 characters</div>
            <div class="flex justify-between items-center mt-1">
                <small class="text-gray-500 text-xs">Minimum 5 characters</small>
                <small id="char-count" class="text-gray-500 text-xs">0 / 5000</small>
            </div>
        </div>
        
        <input type="hidden" id="post-slug" name="postSlug" value="{{ page.fileSlug }}">
        
        <div class="form-actions">
            <button 
                type="submit" 
                class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
                id="submit-btn"
            >
                Submit Comment
            </button>
        </div>
        
        <div id="form-messages" class="hidden">
            <div id="success-message" class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded hidden">
                Comment submitted successfully! It will appear after moderation.
            </div>
            <div id="error-message" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded hidden">
                <span id="error-text"></span>
            </div>
        </div>
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('comment-form');
    const submitBtn = document.getElementById('submit-btn');
    const successMessage = document.getElementById('success-message');
    const errorMessage = document.getElementById('error-message');
    const errorText = document.getElementById('error-text');
    const formMessages = document.getElementById('form-messages');
    
    // Get form fields
    const nameField = document.getElementById('comment-name');
    const emailField = document.getElementById('comment-email');
    const messageField = document.getElementById('comment-message');
    const charCount = document.getElementById('char-count');
    
    // Character counter for message field
    function updateCharCount() {
        const currentLength = messageField.value.length;
        charCount.textContent = `${currentLength} / 5000`;
        
        if (currentLength > 5000) {
            charCount.classList.add('text-red-500');
            charCount.classList.remove('text-gray-500');
        } else if (currentLength < 5) {
            charCount.classList.add('text-gray-500');
            charCount.classList.remove('text-red-500', 'text-green-500');
        } else {
            charCount.classList.add('text-green-500');
            charCount.classList.remove('text-gray-500', 'text-red-500');
        }
    }
    
    // Validation functions
    function validateField(field, validationFn) {
        const isValid = validationFn(field.value);
        const fieldGroup = field.closest('.form-group');
        let errorElement = fieldGroup.querySelector('.field-error');
        
        if (!isValid) {
            field.classList.add('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
            field.classList.remove('border-gray-300', 'focus:ring-blue-500', 'focus:border-blue-500');
            field.setAttribute('aria-invalid', 'true');
            
            if (!errorElement) {
                errorElement = document.createElement('div');
                errorElement.className = 'field-error text-red-500 text-sm mt-1';
                errorElement.setAttribute('role', 'alert');
                errorElement.setAttribute('aria-live', 'polite');
                fieldGroup.appendChild(errorElement);
            }
            errorElement.textContent = getFieldErrorMessage(field, field.value);
            field.setAttribute('aria-describedby', field.getAttribute('aria-describedby') + ' ' + errorElement.className);
        } else {
            field.classList.remove('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
            field.classList.add('border-gray-300', 'focus:ring-blue-500', 'focus:border-blue-500');
            field.removeAttribute('aria-invalid');
            
            if (errorElement) {
                errorElement.remove();
            }
        }
        
        return isValid;
    }
    
    function validateName(value) {
        const trimmed = value.trim();
        if (!trimmed) return false;
        if (trimmed.length > 100) return false;
        return true;
    }
    
    function validateEmail(value) {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        const trimmed = value.trim();
        return trimmed && emailRegex.test(trimmed);
    }
    
    function validateMessage(value) {
        const trimmed = value.trim();
        return trimmed && trimmed.length >= 5 && trimmed.length <= 5000;
    }
    
    function getFieldErrorMessage(field, value) {
        if (field === nameField) {
            const trimmed = value.trim();
            if (!trimmed) return 'Name is required';
            if (trimmed.length > 100) return 'Name must be 100 characters or less';
        } else if (field === emailField) {
            const trimmed = value.trim();
            if (!trimmed) return 'Email is required';
            return 'Please enter a valid email address';
        } else if (field === messageField) {
            const trimmed = value.trim();
            if (!trimmed) return 'Comment is required';
            if (trimmed.length < 5) return 'Comment must be at least 5 characters';
            if (trimmed.length > 5000) return 'Comment must be 5000 characters or less';
        }
        return '';
    }
    
    function validateForm() {
        const nameValid = validateField(nameField, validateName);
        const emailValid = validateField(emailField, validateEmail);
        const messageValid = validateField(messageField, validateMessage);
        
        const isFormValid = nameValid && emailValid && messageValid;
        
        // Update submit button state
        submitBtn.disabled = !isFormValid;
        if (!isFormValid) {
            submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            submitBtn.classList.remove('hover:bg-blue-700');
        } else {
            submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            submitBtn.classList.add('hover:bg-blue-700');
        }
        
        return isFormValid;
    }
    
    // Add real-time validation
    nameField.addEventListener('blur', () => validateForm());
    nameField.addEventListener('input', () => {
        // Clear error on input if field becomes valid
        if (validateName(nameField.value)) {
            validateForm();
        }
    });
    
    emailField.addEventListener('blur', () => validateForm());
    emailField.addEventListener('input', () => {
        if (validateEmail(emailField.value)) {
            validateForm();
        }
    });
    
    messageField.addEventListener('blur', () => validateForm());
    messageField.addEventListener('input', () => {
        updateCharCount();
        if (validateMessage(messageField.value)) {
            validateForm();
        }
    });
    
    // Initial validation state and character count
    updateCharCount();
    validateForm();
    
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // Final validation check
        if (!validateForm()) {
            errorText.textContent = 'Please fix the errors above before submitting.';
            errorMessage.classList.remove('hidden');
            formMessages.classList.remove('hidden');
            return;
        }
        
        // Disable submit button and show loading state
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';
        
        // Hide previous messages
        successMessage.classList.add('hidden');
        errorMessage.classList.add('hidden');
        formMessages.classList.add('hidden');
        
        try {
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            const response = await fetch('/.netlify/functions/comments', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data),
            });
            
            const result = await response.json();
            
            if (response.ok) {
                // Show success message
                successMessage.classList.remove('hidden');
                formMessages.classList.remove('hidden');
                
                // Reset form and validation state
                form.reset();
                updateCharCount();
                validateForm();
            } else {
                throw new Error(result.error || 'Failed to submit comment');
            }
        } catch (error) {
            console.error('Error submitting comment:', error);
            let errorMsg = error.message || 'An error occurred. Please try again.';
            
            // If it's a network error, provide more helpful message
            if (error.message.includes('fetch')) {
                errorMsg = 'Network error. Make sure you\'re running "netlify dev" for local testing.';
            }
            
            errorText.textContent = errorMsg;
            errorMessage.classList.remove('hidden');
            formMessages.classList.remove('hidden');
        } finally {
            // Re-enable submit button
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit Comment';
            validateForm(); // Restore proper button state
        }
    });
});
</script>
