---
layout: layouts/base.njk
---

<article class="max-w-4xl mx-auto py-12">
  <h1 class="font-display text-4xl font-semibold mb-8 text-gray-800 dark:text-parchment-100">{{ title }}</h1>

  <div class="grid md:grid-cols-2 gap-6">
    {% for image in images %}
      <figure class="space-y-2">
        <img src="{{ image.src }}" alt="{{ image.caption | default(title) }}" class="rounded-lg shadow-md" />
        {% if image.caption %}
          <figcaption class="text-sm text-gray-600 dark:text-parchment-400">{{ image.caption }}</figcaption>
        {% endif %}
      </figure>
    {% endfor %}
  </div>

  {% if video %}
    <div class="mt-12">
      <video controls class="w-full rounded-lg shadow-md">
        <source src="{{ video.src }}" type="video/mp4" />
        Your browser does not support the video element.
      </video>
      {% if video.caption %}
        <p class="mt-2 text-sm text-gray-600 dark:text-parchment-400">{{ video.caption }}</p>
      {% endif %}
    </div>
  {% endif %}
</article>
