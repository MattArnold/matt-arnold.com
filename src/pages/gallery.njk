---
title: Gallery
layout: layouts/base.njk
permalink: /gallery/
eleventyNavigation:
  key: Gallery
  order: 3
---

<div class="space-y-12">
  <!-- Introduction -->
  <div class="text-center max-w-3xl mx-auto space-y-4">
    <p class="text-xl text-gray-600 dark:text-parchment-200 leading-relaxed">
      More galleries coming soon.
    </p>
  </div>

  <!-- Gallery Sections -->
  <div class="space-y-16">
    {% for g in collections.galleries %}
      <section class="space-y-8">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-gradient-to-br from-gold-ochre-400 to-gold-ochre-600 rounded-lg flex items-center justify-center"></div>
          <h2 class="font-display text-3xl font-semibold text-gray-800 dark:text-parchment-100">{{ g.data.title }}</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <a href="{{ g.url }}" class="aspect-square overflow-hidden rounded-xl border border-gold-ochre-200 dark:border-gold-ochre-700 hover:shadow-lg transition-all duration-300">
            <img src="{{ g.data.images[0].src }}" alt="{{ g.data.title }} thumbnail" class="object-cover w-full h-full"/>
          </a>
        </div>
      </section>
    {% endfor %}
  </div>
</div>
