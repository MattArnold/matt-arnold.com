---
title: Search
layout: layouts/base.njk
permalink: /search/
eleventyNavigation:
  key: Search
  order: 5
---

<div class="max-w-4xl mx-auto">
  <div class="mb-8">
    <div class="relative">
      <input 
        type="text" 
        id="search-input" 
        placeholder="Search articles, pages, and content..." 
        class="w-full px-4 py-3 text-lg border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-800 dark:border-gray-600 dark:text-white"
        autocomplete="off"
      >
      <div class="absolute right-3 top-3 text-gray-400">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
    </div>
    
    <div class="mt-2 text-sm text-gray-600 dark:text-gray-400">
      <span id="search-stats" class="hidden">Found <span id="search-count">0</span> results</span>
      <span id="search-help">Start typing to search. Supports partial matches and typos.</span>
    </div>
  </div>

  <div id="search-results" class="space-y-6">
    <!-- Results will be inserted here -->
  </div>
  
  <div id="no-results" class="hidden text-center py-12">
    <div class="text-gray-500 dark:text-gray-400">
      <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
      <h3 class="text-lg font-medium mb-2">No results found</h3>
      <p>Try different keywords or check your spelling</p>
    </div>
  </div>
</div>

<script>
// Search functionality will be loaded from the main JavaScript bundle
document.addEventListener('DOMContentLoaded', function() {
  if (window.initializeSearch) {
    window.initializeSearch();
  }
});
</script>
