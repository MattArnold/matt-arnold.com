---
layout: layouts/base.njk
title: Site Updates
permalink: /updates/
eleventyNavigation:
  key: Updates
  order: 8
---

<div class="prose prose-lg max-w-none dark:prose-invert">
  <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
    By looking at this page, you don't have to wonder whether I added something new to the site.
  </p>

  <div class="mb-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
    <div class="flex items-center">
      <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"/>
      </svg>
      <span class="text-sm text-blue-800 dark:text-blue-200">
        <a href="/rss.xml" class="font-medium hover:underline">Subscribe to RSS feed</a> to get notified of new content updates
      </span>
    </div>
  </div>

  <h2>Update History</h2>

  {% if contentUpdates.updates and contentUpdates.updates.length > 0 %}
    <div class="space-y-6">
      {% for update in contentUpdates.updates %}
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6 bg-white dark:bg-gray-800/50">
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mt-0">
              {{ update.date | readableDate }}
            </h3>
          </div>
          
          {% if update.links and update.links.length > 0 %}
            {# Build unique base URLs for grouping anchors #}
            {% set bases = [] %}
            {% for l in update.links %}
              {% set base = l.url.split('#')[0] %}
              {% if bases.indexOf(base) < 0 %}
                {% set bases = bases.concat([base]) %}
              {% endif %}
            {% endfor %}
            <ul class="list-none pl-0 space-y-1">
              {% for base in bases %}
                <li>
                  {# Determine title: prefer link with exact base URL, else derive from path #}
                  {% set parentLink = null %}
                  {% for linkItem in update.links %}
                    {% if linkItem.url == base %}
                      {% set parentLink = linkItem %}
                    {% endif %}
                  {% endfor %}
                  {% if parentLink %}
                    {% set title = parentLink.title %}
                  {% else %}
                    {% set slug = base | replace('/', '') | replace('-', ' ' ) %}
                    {% set title = slug | title %}
                  {% endif %}
                  <a href="{{ base }}" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium">
                    {{ title }}
                  </a>
                  {# Nested anchors #}
                  {% set anchors = [] %}
                  {% for linkItem in update.links %}
                    {% set parts = linkItem.url.split('#') %}
                    {% if parts[0] == base and parts.length > 1 %}
                      {% set anchors = anchors.concat([linkItem]) %}
                    {% endif %}
                  {% endfor %}
                  {% if anchors.length %}
                    <ul class="ml-4 list-none space-y-1">
                      {% for a in anchors %}
                        <li>
                          <a href="{{ a.url }}" class="text-blue-500 dark:text-blue-300 hover:underline">
                            {{ a.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="text-center py-12 text-gray-500 dark:text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <p>No updates recorded yet.</p>
    </div>
  {% endif %}
</div>
