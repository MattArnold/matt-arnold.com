---
layout: layouts/base.njk
title: Site Updates
permalink: /updates/
eleventyNavigation:
  key: Updates
  order: 6
---

<div class="prose prose-lg max-w-none dark:prose-invert">
  <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
    By looking at this page, you don't have to wonder whether I added something new to the site.
  </p>

  <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
    (But don't let that stop you from enjoying browsing at random.)
  </p>

  {% if contentUpdates.lastContentUpdate %}
  <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-blue-900 dark:text-blue-100 mt-0 mb-2">Latest Update</h2>
    <p class="text-blue-800 dark:text-blue-200 mb-0">
      Last content update: <strong>{{ contentUpdates.lastContentUpdate | readableDate }}</strong>
    </p>
  </div>
  {% endif %}

  <h2>Update History</h2>

  {% if contentUpdates.updates and contentUpdates.updates.length > 0 %}
    <div class="space-y-6">
      {% for update in contentUpdates.updates %}
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-6 bg-white dark:bg-gray-800/50">
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mt-0">
              {{ update.date | readableDate }}
            </h3>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              {% if update.type == 'auto' %}bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300
              {% elif update.type == 'system' %}bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300
              {% else %}bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300{% endif %}">
              {{ update.type | title }}
            </span>
          </div>
          
          <p class="text-gray-700 dark:text-gray-300 mb-4">{{ update.description }}</p>
          
          {% if update.links and update.links.length > 0 %}
            <div>
              <h4 class="text-sm font-medium text-gray-900 dark:text-gray-100 mb-2">Affected Pages:</h4>
              <ul class="list-none pl-0 space-y-1">
                {% for link in update.links %}
                  <li>
                    <a href="{{ link.url }}" 
                       class="inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 transition-colors">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                      {{ link.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
          
          {% if update.files and update.files.length > 0 %}
            <details class="mt-4">
              <summary class="text-sm text-gray-600 dark:text-gray-400 cursor-pointer hover:text-gray-800 dark:hover:text-gray-200">
                Show technical details ({{ update.files.length }} files)
              </summary>
              <ul class="mt-2 text-xs text-gray-500 dark:text-gray-500 font-mono space-y-1">
                {% for file in update.files %}
                  <li>{{ file }}</li>
                {% endfor %}
              </ul>
            </details>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="text-center py-12 text-gray-500 dark:text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <p>No updates recorded yet.</p>
    </div>
  {% endif %}
</div>
